{
  "name": "playwirther",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "npx dotenv-cli -e .env.local prisma generate",
    "db:push": "npx dotenv-cli -e .env.local prisma db push",
    "db:migrate": "npx dotenv-cli -e .env.local prisma migrate dev",
    "db:seed": "npx dotenv-cli -e .env.local tsx prisma/seed.ts",
    "db:studio": "npx dotenv-cli -e .env.local prisma studio",
    "worker:dev": "npx dotenv-cli -e .env.local -- tsx watch workers/index.ts",
    "worker:start": "npx dotenv-cli -e .env.local -- tsx workers/index.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.750.0",
